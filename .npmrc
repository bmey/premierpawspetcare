# --- Supply-chain hardening -------------------------------------------------
# Refuse to install any package version published less than 14 days ago.
#
# Why: compromised package versions (e.g. the Sept 2025 npm worm, the Mar 2026
# axios RAT) are almost always detected and unpublished within hours-to-days.
# A two-week cooldown means we never pull a freshly-poisoned release; by the
# time we're allowed to install it, the ecosystem has had time to catch it.
#
# Enforcement requires npm >= 11.10.0 (ships with Node 24 LTS — see .nvmrc).
# On older npm this line is read but NOT enforced; the Dependabot cooldown in
# .github/dependabot.yml is the version-independent backstop.
min-release-age=14
