---
import { Picture } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PartnerLogoWall from '../components/PartnerLogoWall.astro';
import partnerHero from '../assets/partner_istockphoto.jpg';
import site from '../data/site.json';

const pillars = [
  {
    title: "Your clients in capable hands",
    description: "When you refer a family to us, they're cared for by a team that includes licensed veterinary technicians — so your treatment plan is carried out safely and consistently.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h-1a2 2 0 0 0 -2 2v3.5a5.5 5.5 0 0 0 11 0v-3.5a2 2 0 0 0 -2 -2h-1"/><path d="M8 15a6 6 0 1 0 12 0v-3"/><path d="M11 3v2"/><path d="M6 3v2"/><path d="M18 10a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"/></svg>`,
  },
  {
    title: "A referral that reflects well on you",
    description: "We're a locally owned, insured, Chamber-member business serving Bear, Middletown, and Odessa. Sending a client our way upholds the standard of care your practice is known for.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.46 20.846a12 12 0 0 1 -7.96 -14.846a12 12 0 0 0 8.5 -3a12 12 0 0 0 8.5 3a12 12 0 0 1 -.09 7.06"/><path d="M15 19l2 2l4 -4"/></svg>`,
  },
  {
    title: "We extend your care into the home",
    description: "Medication administration, post-op monitoring, and quality-of-life support — we carry your treatment plan from the exam room into the home, and keep you in the loop.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l-2 0l9 -9l9 9l-2 0"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7"/><path d="M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6"/></svg>`,
  },
  {
    title: "Referrals that go both ways",
    description: "Most partners refer their clients to us — and when a family needs a specialist, we point them right back to you. Partnership means a real two-way relationship, not a listing in a directory.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7l-18 0"/><path d="M18 4l3 3l-3 3"/><path d="M3 17l18 0"/><path d="M6 14l-3 3l3 3"/></svg>`,
  },
];

const steps = [
  {
    number: "01",
    title: "Reach out",
    description: "Tell us about your practice and how you'd like to work together using the form below.",
  },
  {
    number: "02",
    title: "Let's talk",
    description: "We'll set up a quick call or visit to align on referrals, communication, and what success looks like.",
  },
  {
    number: "03",
    title: "Start referring",
    description: "You refer clients who'd benefit from in-home care, and we keep the loop open so care stays coordinated — sending families your way when they need you, too.",
  },
];

const inputClass = "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition";
const labelClass = "block text-sm font-semibold text-black mb-1.5";
---

<Layout
  title="Partner With Premier Paws Pet Care | Partnerships"
  description="Partner with Premier Paws Pet Care — join our trusted network of veterinary and pet-care professionals serving Bear, Middletown, and Odessa, Delaware."
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="relative overflow-hidden bg-black min-h-[560px] lg:min-h-[640px] flex items-center">

      <!-- Full-bleed background image — optimized to AVIF/WebP at multiple sizes -->
      <Picture
        src={partnerHero}
        formats={['avif', 'webp']}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        quality={82}
        alt="Premier Paws collaborating with a partner practice"
        class="absolute inset-0 w-full h-full object-cover object-[center_25%] translate-x-[7%] lg:scale-110 lg:translate-x-[15%]"
        loading="eager"
        fetchpriority="high"
      />

      <!-- Dark gradient overlay — opaque on the left where text lives, fades out toward the subjects.
           Mobile keeps more coverage for legibility; desktop lets the fade run further right. -->
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/60 to-transparent from-0% via-100% to-100% lg:via-black/80 lg:via-45% lg:to-80% pointer-events-none"></div>

      <div class="relative max-w-6xl mx-auto px-6 py-20 lg:py-24 w-full">
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 bg-white/10 text-violet-300 text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
            <span class="w-2 h-2 bg-violet-400 rounded-full"></span>
            Partnerships
          </div>
          <h1 class="text-4xl lg:text-5xl font-black text-white tracking-tight leading-[1.1] mb-6">
            Better care happens when<br/>we work <span class="text-violet-400">together.</span>
          </h1>
          <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-md">
            Veterinary practices, urgent care hospitals, specialty services, and end-of-life care providers across New Castle County refer their clients to Premier Paws for skilled, in-home support — so pets and their families receive top-notch care between appointments.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="#partner-inquiry"
              class="inline-flex items-center bg-violet-600 hover:bg-violet-700 text-white font-semibold text-sm px-8 py-4 rounded-full transition-colors shadow-lg shadow-violet-900/40"
            >
              Become a Partner
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a
              href={`tel:${site.phone}`}
              class="inline-flex items-center border-2 border-white/30 hover:bg-white hover:text-black text-white font-semibold text-sm px-8 py-4 rounded-full transition-colors"
            >
              Talk to Our Team
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Why we value partnerships -->
    <section class="bg-white py-20 lg:py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="max-w-2xl mx-auto text-center">
          <p class="text-violet-600 font-semibold text-sm uppercase tracking-widest mb-3">Our Philosophy</p>
          <h2 class="text-4xl lg:text-5xl font-black text-black tracking-tight mb-6">Together we have it all.</h2>
        </div>
        <div class="max-w-3xl mx-auto space-y-5 text-gray-600 text-lg leading-relaxed">
          <p>
            We're a licensed, veterinary-technician-led, in-home care team — and we know the pets we look after are healthiest when the people caring for them communicate.
          </p>
          <p>
            When you refer a client to us, we carry your treatment plan into the home and keep continuity of care from the exam room to the couch. Your clients get skilled in-home support, you stay informed, and pets get a team that genuinely works together.
          </p>
        </div>
      </div>
    </section>

    <!-- The value of partnering -->
    <section class="bg-black py-20 lg:py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="text-violet-400 font-semibold text-sm uppercase tracking-widest mb-3">Why Partner With Us</p>
          <h2 class="text-4xl lg:text-5xl font-black text-white tracking-tight mb-4">What a partnership offers.</h2>
          <p class="text-white/60 text-lg max-w-xl mx-auto">
            A partnership with Premier Paws is built on trust, communication, and a shared commitment to the pets and families we both serve.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {pillars.map((pillar) => (
            <div class="bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl p-6 transition-colors">
              <div class="text-violet-400 mb-4">
                <Fragment set:html={pillar.icon} />
              </div>
              <h3 class="font-bold text-white mb-2">{pillar.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{pillar.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Current partners (logos only) -->
    <section class="bg-white py-20 lg:py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="text-violet-600 font-semibold text-sm uppercase tracking-widest mb-3">Our Partners</p>
          <h2 class="text-4xl lg:text-5xl font-black text-black tracking-tight mb-4">The partners we trust.</h2>
          <p class="text-gray-500 text-lg max-w-xl mx-auto">
            A growing circle of local providers we're proud to work alongside.
          </p>
        </div>

        <PartnerLogoWall />
      </div>
    </section>

    <!-- How to become a partner + inquiry form -->
    <section id="partner-inquiry" class="bg-black py-20 lg:py-28">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Steps -->
        <div class="text-center mb-16">
          <p class="text-violet-400 font-semibold text-sm uppercase tracking-widest mb-3">Getting Started</p>
          <h2 class="text-4xl lg:text-5xl font-black text-white tracking-tight">How partnership works.</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8 lg:gap-12 mb-20">
          {steps.map((step, i) => (
            <div class="relative text-center group">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-violet-600 group-hover:bg-violet-700 text-white font-black text-lg mb-6 shadow-lg shadow-violet-900/40 transition-colors">
                {step.number}
              </div>

              {i < steps.length - 1 && (
                <div class="hidden md:block absolute top-8 left-[calc(50%+2.5rem)] right-[calc(-50%+2.5rem)] flex items-center justify-center pointer-events-none">
                  <div class="w-full h-px bg-white/15 relative">
                    <svg class="absolute right-0 top-1/2 -translate-y-1/2 text-white/25 w-3 h-3" fill="currentColor" viewBox="0 0 8 8">
                      <path d="M0 0l8 4-8 4V0z"/>
                    </svg>
                  </div>
                </div>
              )}

              <h3 class="font-bold text-xl text-white mb-3">{step.title}</h3>
              <p class="text-white/50 leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>

        <!-- Inquiry form -->
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start border-t border-white/10 pt-16">

          <!-- Left info panel -->
          <div class="lg:pt-2">
            <p class="text-violet-400 font-semibold text-sm uppercase tracking-widest mb-3">Get In Touch</p>
            <h2 class="text-3xl lg:text-4xl font-black text-white tracking-tight leading-[1.1] mb-6">
              Let's build something good for local pets <span class="text-violet-400">together.</span>
            </h2>
            <p class="text-white/60 text-lg leading-relaxed mb-8">
              Tell us about your practice and how you'd like to work together. We'll respond within 24 hours.
            </p>

            <a
              href={`tel:${site.phone}`}
              class="flex items-center gap-3 text-white/70 hover:text-white transition-colors group w-fit"
            >
              <div class="w-10 h-10 rounded-full bg-white/10 group-hover:bg-violet-600 flex items-center justify-center flex-shrink-0 transition-colors">
                <svg class="w-5 h-5 text-violet-400 group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" />
                </svg>
              </div>
              <span>{site.phone}</span>
            </a>
          </div>

          <!-- Right form -->
          <div class="bg-white rounded-2xl p-8 shadow-xl">
            <!-- Posts to the dedicated partnership Formspree endpoint. -->
            <form
              action="https://formspree.io/f/xrevljlo"
              method="POST"
              class="space-y-5"
            >
              <input type="hidden" name="_subject" value="New Partnership Inquiry" />

              <!-- Name -->
              <div>
                <label for="name" class={labelClass}>
                  Your Name <span class="text-red-500">*</span>
                </label>
                <input type="text" id="name" name="name" required placeholder="Jane Smith" class={inputClass} />
              </div>

              <!-- Business -->
              <div>
                <label for="business" class={labelClass}>
                  Business / Organization <span class="text-red-500">*</span>
                </label>
                <input type="text" id="business" name="business" required placeholder="e.g. Companion Animal Veterinary Associates" class={inputClass} />
              </div>

              <!-- Email + Phone -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="email" class={labelClass}>
                    Email <span class="text-red-500">*</span>
                  </label>
                  <input type="email" id="email" name="email" required placeholder="jane@example.com" class={inputClass} />
                </div>
                <div>
                  <label for="phone" class={labelClass}>Phone</label>
                  <input type="tel" id="phone" name="phone" placeholder="(302) 555-0123" class={inputClass} />
                </div>
              </div>

              <!-- Type of business -->
              <div>
                <label for="business_type" class={labelClass}>Type of business</label>
                <select id="business_type" name="business_type" class={`${inputClass} bg-white`}>
                  <option value="">Select...</option>
                  <option value="Veterinary Practice">Veterinary Practice</option>
                  <option value="Veterinary Specialist">Veterinary Specialist</option>
                  <option value="End-of-Life Care">End-of-Life Care</option>
                  <option value="Grooming">Grooming</option>
                  <option value="Training">Training</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <!-- How would you like to partner -->
              <div>
                <label for="partnership" class={labelClass}>
                  How would you like to partner? <span class="text-red-500">*</span>
                </label>
                <textarea id="partnership" name="partnership" required rows="3" placeholder="Tell us a bit about your practice and what you have in mind." class={`${inputClass} resize-none`}></textarea>
              </div>

              <!-- Notes -->
              <div>
                <label for="notes" class={labelClass}>Anything else we should know?</label>
                <textarea id="notes" name="notes" rows="2" placeholder="Optional" class={`${inputClass} resize-none`}></textarea>
              </div>

              <button
                type="submit"
                class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold py-3.5 rounded-xl transition-colors text-sm"
              >
                Send Partnership Inquiry
              </button>
              <p class="text-center text-xs text-gray-400">We'll respond within 24 hours.</p>
            </form>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
