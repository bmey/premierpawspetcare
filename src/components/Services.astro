---
import services from '../data/services.json';

const categoryIcons: Record<string, string> = {
  medical: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  premium: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  basic: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
};

const themeStyles: Record<string, { header: string; badge: string; dot: string; border: string }> = {
  medical: {
    header: 'bg-violet-600 text-white',
    badge: 'bg-white/20 text-white',
    dot: 'bg-white/70',
    border: 'border-violet-200',
  },
  premium: {
    header: 'bg-zinc-900 text-white',
    badge: 'bg-white/15 text-white',
    dot: 'bg-white/60',
    border: 'border-zinc-200',
  },
  basic: {
    header: 'bg-violet-50 text-violet-900',
    badge: 'bg-violet-100 text-violet-700',
    dot: 'bg-violet-400',
    border: 'border-violet-100',
  },
};
---

<section id="services" class="bg-white py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-violet-600 font-semibold text-sm uppercase tracking-widest mb-3">What We Offer</p>
      <h2 class="text-4xl lg:text-5xl font-black text-black tracking-tight mb-4">Our Services</h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        Comprehensive pet care tailored to your animal's needs — from daily visits to highly skilled medical care.
      </p>
    </div>

    <!-- Category panels -->
    <div class="space-y-8">
      {services.map((category) => {
        const theme = themeStyles[category.theme];
        return (
          <div class={`rounded-2xl overflow-hidden border ${theme.border} shadow-sm`}>

            <!-- Category header -->
            <div class={`${theme.header} px-8 py-6`}>
              <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-2">
                <div class={`inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full w-fit ${theme.badge}`}>
                  <Fragment set:html={categoryIcons[category.theme]} />
                  {category.tagline}
                </div>
              </div>
              <h3 class="text-2xl font-black tracking-tight mb-1">{category.category}</h3>
              <p class="opacity-75 text-sm leading-relaxed max-w-2xl">{category.description}</p>
            </div>

            <!-- Services grid -->
            <div class="bg-white p-6 md:p-8">
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {category.services.map((service) => (
                  <div class="flex gap-3">
                    <div class={`mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0 ${theme.dot}`}></div>
                    <div>
                      <p class="font-semibold text-black text-sm">{service.name}</p>
                      <p class="text-gray-500 text-xs leading-relaxed mt-0.5">{service.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

          </div>
        );
      })}
    </div>

    <!-- Disclaimer -->
    <div class="flex items-start gap-2.5 mt-8 bg-violet-50 border border-violet-100 rounded-xl px-5 py-4">
      <svg class="w-4 h-4 text-violet-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-violet-700 text-xs leading-relaxed">
        <strong>Disclaimer:</strong> Licensed veterinary technicians are not able to diagnose, perform surgery, or give prognosis.
      </p>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-700 text-white font-semibold text-sm px-8 py-4 rounded-full transition-colors shadow-lg shadow-violet-200"
      >
        Book a Service
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
