---
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import WhyUs from '../components/WhyUs.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import ServiceArea from '../components/ServiceArea.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import heroImg from '../assets/hero.jpg';

// Resolve the actual Astro-optimized URL for the hero image so we can
// preload the correct hashed file rather than the original source.
const preloadHero = await getImage({ src: heroImg, format: 'avif', width: 1920, quality: 82 });
---

<Layout>
  <link slot="head" rel="preload" as="image" href={preloadHero.src} fetchpriority="high" />
  <Nav />
  <main>
    <Hero />
    <Services />
    <WhyUs />
    <HowItWorks />
    <Testimonials />
    <ServiceArea />
    <Contact />
  </main>
  <Footer />
</Layout>
