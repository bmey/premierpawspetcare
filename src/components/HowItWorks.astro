---
const steps = [
  {
    number: "01",
    title: "Get in Touch",
    description: "Fill out our contact form or give us a call. Tell us about your pet, the services you need, and your schedule.",
  },
  {
    number: "02",
    title: "Meet & Greet",
    description: "We schedule a free meet and greet so your pet can get comfortable with their new caregiver before service begins.",
  },
  {
    number: "03",
    title: "Relax & Enjoy",
    description: "We take care of everything. You'll receive updates, photos, and report cards so you can relax knowing your pet is thriving.",
  },
];
---

<section id="how-it-works" class="bg-white py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-violet-600 font-semibold text-sm uppercase tracking-widest mb-3">Getting Started</p>
      <h2 class="text-4xl lg:text-5xl font-black text-black tracking-tight mb-4">How It Works</h2>
      <p class="text-gray-500 text-lg max-w-md mx-auto">
        Getting started is simple. Three easy steps to premium pet care.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step, i) => (
        <div class="relative text-center group">
          <!-- Step number circle -->
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-violet-600 group-hover:bg-violet-700 text-white font-black text-lg mb-6 shadow-lg shadow-violet-200 transition-colors">
            {step.number}
          </div>

          <!-- Connector arrow (between cards, desktop only) -->
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[calc(50%+2.5rem)] right-[calc(-50%+2.5rem)] flex items-center justify-center pointer-events-none">
              <div class="w-full h-px bg-violet-200 relative">
                <svg class="absolute right-0 top-1/2 -translate-y-1/2 text-violet-300 w-3 h-3" fill="currentColor" viewBox="0 0 8 8">
                  <path d="M0 0l8 4-8 4V0z"/>
                </svg>
              </div>
            </div>
          )}

          <h3 class="font-bold text-xl text-black mb-3">{step.title}</h3>
          <p class="text-gray-500 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-14">
      <a
        href="#contact"
        class="inline-flex items-center bg-violet-600 hover:bg-violet-700 text-white font-semibold text-sm px-8 py-4 rounded-full transition-colors shadow-lg shadow-violet-200"
      >
        Start with a Free Meet & Greet
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
