---
import site from '../data/site.json';
---

<footer class="bg-black border-t border-white/10">
  <div class="max-w-6xl mx-auto px-6 py-14">
    <div class="grid md:grid-cols-3 gap-10 mb-12">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-block text-white font-extrabold text-xl tracking-tight mb-4">
          Premier Paws<span class="text-violet-400">.</span>
        </a>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs mb-5">
          Professional, loving pet care you can trust. Licensed, insured, and background-checked.
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          <a
            href={site.social.instagram}
            aria-label="Instagram"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-violet-600 flex items-center justify-center transition-colors"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href={site.social.facebook}
            aria-label="Facebook"
            class="w-9 h-9 rounded-full bg-white/10 hover:bg-violet-600 flex items-center justify-center transition-colors"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-5">Quick Links</h4>
        <nav class="space-y-3">
          <a href="#services" class="block text-white/50 hover:text-white text-sm transition-colors">Services</a>
          <a href="#why-us" class="block text-white/50 hover:text-white text-sm transition-colors">About</a>
          <a href="#testimonials" class="block text-white/50 hover:text-white text-sm transition-colors">Reviews</a>
          <a href="#service-area" class="block text-white/50 hover:text-white text-sm transition-colors">Service Area</a>
          <a href="#contact" class="block text-white/50 hover:text-white text-sm transition-colors">Contact</a>
          <a href="https://shop.premierpawspetcare.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-violet-400 hover:text-violet-300 text-sm transition-colors">
            Shop Merch
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6"/><path d="M11 13l9 -9"/><path d="M15 4h5v5"/></svg>
          </a>
        </nav>
      </div>

      <!-- Contact info -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-5">Contact</h4>
        <div class="space-y-3">
          <a href={`tel:${site.phone}`} class="block text-white/50 hover:text-white text-sm transition-colors">{site.phone}</a>
          <a href={`mailto:${site.email}`} class="block text-white/50 hover:text-white text-sm transition-colors">{site.email}</a>
          <p class="text-white/50 text-sm">{site.hours}</p>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/30 text-xs">
        &copy; {new Date().getFullYear()} Premier Paws Pet Care. All rights reserved.
      </p>
      <p class="text-white/20 text-xs">Licensed &middot; Insured &middot; Background Checked</p>
    </div>
  </div>
</footer>
