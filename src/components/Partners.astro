---
import PartnerLogoWall from './PartnerLogoWall.astro';
---

<section id="partners" class="bg-violet-50 py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-14">
      <p class="text-violet-600 font-semibold text-sm uppercase tracking-widest mb-3">Our Partners</p>
      <h2 class="text-4xl lg:text-5xl font-black text-black tracking-tight mb-4">
        Providing care that's <span class="text-violet-600">cooperative</span>.
      </h2>
      <p class="text-gray-500 text-lg max-w-4xl mx-auto">
        Exceptional care happens when everyone works together. Our Licensed Veterinary Technicians collaborate with your pet's veterinarian to provide skilled in-home support, helping ensure treatment plans are carried out safely and consistently between appointments.
      </p>
    </div>

    <PartnerLogoWall />

    <div class="text-center mt-14">
      <a
        href="/partners"
        class="inline-flex items-center bg-violet-600 hover:bg-violet-700 text-white font-semibold text-sm px-8 py-4 rounded-full transition-colors shadow-lg shadow-violet-200"
      >
        Partner With Us
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
