<section class="relative bg-white overflow-hidden">
  <!-- Soft purple gradient blob (decorative) -->
  <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-violet-100 rounded-full blur-3xl opacity-60 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text content -->
      <div>
        <div class="inline-flex items-center gap-2 bg-violet-50 text-violet-700 text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
          <span class="w-2 h-2 bg-violet-500 rounded-full"></span>
          Insured · Bonded · Background Checked
        </div>

        <h1 class="text-5xl lg:text-6xl font-black text-black leading-[1.05] tracking-tight mb-6">
          Pet Care You<br/>Can <span class="text-violet-600">Trust.</span>
        </h1>

        <p class="text-gray-500 text-lg leading-relaxed mb-8 max-w-md">
          From daily dog walks to overnight stays, Premier Paws Pet Care treats your pets like family. Professional, reliable, and always loving.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="#contact"
            class="inline-flex items-center bg-violet-600 hover:bg-violet-700 text-white font-semibold text-sm px-8 py-4 rounded-full transition-colors shadow-lg shadow-violet-200"
          >
            Book a Consultation
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="#services"
            class="inline-flex items-center border-2 border-black hover:bg-black hover:text-white text-black font-semibold text-sm px-8 py-4 rounded-full transition-colors"
          >
            Our Services
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex flex-wrap items-center gap-5 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-500 fill-current" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span>5-star rated</span>
          </div>
          <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <span>Fully insured</span>
          </div>
          <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>GPS tracked walks</span>
          </div>
        </div>
      </div>

      <!-- Hero image area -->
      <div class="relative">
        <img src="/images/hero.jpg" alt="A happy dog being cared for by Premier Paws Pet Care" class="w-full h-full object-cover rounded-3xl" />

        <!-- Floating social proof badge -->
        <div class="absolute -bottom-5 -left-4 bg-black text-white rounded-2xl px-5 py-3 shadow-xl">
          <p class="text-xs text-white/50 mb-0.5">Happy families</p>
          <p class="font-bold text-base leading-tight">100+ pets <span class="text-violet-400">loved</span></p>
        </div>
      </div>

    </div>
  </div>
</section>
