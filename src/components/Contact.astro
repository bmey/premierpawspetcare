---
import site from '../data/site.json';
---

<section id="contact" class="bg-black py-20 lg:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left info panel -->
      <div class="lg:pt-2">
        <p class="text-violet-400 font-semibold text-sm uppercase tracking-widest mb-3">Get In Touch</p>
        <h2 class="text-4xl lg:text-5xl font-black text-white tracking-tight leading-[1.1] mb-6">
          Let's care for<br/>your pet <span class="text-violet-400">together.</span>
        </h2>
        <p class="text-white/60 text-lg leading-relaxed mb-8">
          Ready to get started? Fill out the form and we'll respond within 24 hours to schedule your free meet and greet.
        </p>

        <!-- Large logo -->
        <img
          src="/images/logo.png"
          alt="Premier Paws Pet Care"
          class="rounded-2xl mb-8 w-full max-w-sm"
        />

        <div class="space-y-4">
          <a
            href={`tel:${site.phone}`}
            class="flex items-center gap-3 text-white/70 hover:text-white transition-colors group"
          >
            <div class="w-10 h-10 rounded-full bg-white/10 group-hover:bg-violet-600 flex items-center justify-center flex-shrink-0 transition-colors">
              <svg class="w-5 h-5 text-violet-400 group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" />
              </svg>
            </div>
            <span>{site.phone}</span>
          </a>

          <a
            href={`mailto:${site.email}`}
            class="flex items-center gap-3 text-white/70 hover:text-white transition-colors group"
          >
            <div class="w-10 h-10 rounded-full bg-white/10 group-hover:bg-violet-600 flex items-center justify-center flex-shrink-0 transition-colors">
              <svg class="w-5 h-5 text-violet-400 group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" />
                <path d="M3 7l9 6l9 -6" />
              </svg>
            </div>
            <span>{site.email}</span>
          </a>

          <div class="flex items-center gap-3 text-white/70">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-violet-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
                <path d="M12 7v5l3 3" />
              </svg>
            </div>
            <span>{site.hours}</span>
          </div>
        </div>
      </div>

      <!-- Right form -->
      <div class="bg-white rounded-2xl p-8 shadow-xl">
        <form
          action="https://formspree.io/f/mnjgypnv"
          method="POST"
          class="space-y-5"
        >

          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-black mb-1.5">
              Your Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-black mb-1.5">
              Email Address <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@example.com"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
            />
          </div>

          <!-- Primary Pet section -->
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-4 space-y-4">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Primary Pet</p>

            <div class="grid grid-cols-2 gap-4">
              <!-- Species -->
              <div>
                <label for="species" class="block text-sm font-semibold text-black mb-1.5">
                  Species <span class="text-red-500">*</span>
                </label>
                <select
                  id="species"
                  name="species"
                  required
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
                >
                  <option value="">Select...</option>
                  <option value="Dog">Dog</option>
                  <option value="Cat">Cat</option>
                  <option value="Bird">Bird</option>
                  <option value="Exotic">Exotic</option>
                  <option value="Large Animal">Large Animal</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <!-- Age -->
              <div>
                <label for="age" class="block text-sm font-semibold text-black mb-1.5">Age</label>
                <input
                  type="text"
                  id="age"
                  name="age"
                  placeholder="e.g. 3 years"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
                />
              </div>
            </div>

            <!-- Breed -->
            <div>
              <label for="breed" class="block text-sm font-semibold text-black mb-1.5">Breed</label>
              <input
                type="text"
                id="breed"
                name="breed"
                placeholder="e.g. Golden Retriever"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
              />
            </div>
          </div>

          <!-- Requested Services -->
          <div>
            <label for="services" class="block text-sm font-semibold text-black mb-1.5">
              Requested Services <span class="text-red-500">*</span>
            </label>
            <textarea
              id="services"
              name="services"
              required
              rows="2"
              placeholder="e.g. Dog walking 3x/week, drop-in visits on weekends"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <!-- Multiple pets toggle -->
          <div>
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input
                type="checkbox"
                id="multi-pet-toggle"
                name="multiple_pets"
                value="yes"
                class="w-4 h-4 accent-violet-600 cursor-pointer"
              />
              <span class="text-sm font-medium text-black">I'm inquiring about multiple pets</span>
            </label>
            <div id="additional-pets-field" class="hidden mt-3">
              <label for="additional-pets" class="block text-sm font-semibold text-black mb-1.5">
                Additional Pets
              </label>
              <textarea
                id="additional-pets"
                name="additional_pets"
                rows="3"
                placeholder="Please describe your other pets (species, breed, age, any special needs)"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition resize-none"
              ></textarea>
            </div>
          </div>

          <!-- Notes -->
          <div>
            <label for="notes" class="block text-sm font-semibold text-black mb-1.5">
              Anything else we should know?
            </label>
            <textarea
              id="notes"
              name="notes"
              rows="3"
              placeholder="Allergies, special needs, behavioral notes, preferred schedule, etc."
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold py-3.5 rounded-xl transition-colors text-sm"
          >
            Send Message
          </button>
          <p class="text-center text-xs text-gray-400">We'll respond within 24 hours.</p>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById('multi-pet-toggle') as HTMLInputElement | null;
  const field = document.getElementById('additional-pets-field');

  toggle?.addEventListener('change', () => {
    field?.classList.toggle('hidden', !toggle.checked);
  });
</script>
